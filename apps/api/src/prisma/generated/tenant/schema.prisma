generator client {
  provider = "prisma-client-js"
  output   = "../src/prisma/generated/tenant"
}

datasource db {
  provider = "postgresql"
  url      = env("TENANT_DATABASE_URL")
}

enum Currency {
  IRR
}

enum InvoicePaymentStatus {
  PAID
  PARTIALLY_PAID
  UNPAID
}

enum InventoryTxnType {
  IN
  OUT
  ADJUST
  TRANSFER
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum PaymentDirection {
  IN
  OUT
  TRANSFER
}

model Permission {
  id          String  @id @default(uuid())
  key         String  @unique
  description String?

  roles RolePermission[]
}

model Role {
  id        String   @id @default(uuid())
  key       String   @unique
  nameFa    String
  isSystem  Boolean  @default(true)
  createdAt DateTime @default(now())

  permissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Customer {
  id         String   @id @default(uuid())
  name       String
  phone      String?
  email      String?
  address    String?
  nationalId String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  salesInvoices SalesInvoice[]
}

model Supplier {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseInvoices PurchaseInvoice[]
}

model Unit {
  id        String   @id @default(uuid())
  key       String   @unique
  nameFa    String
  createdAt DateTime @default(now())

  products Product[]
}

model ProductCategory {
  id        String   @id @default(uuid())
  nameFa    String
  parentId  String?
  createdAt DateTime @default(now())

  parent   ProductCategory?  @relation("CategoryParent", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryParent")
  products Product[]
}

model Product {
  id            String   @id @default(uuid())
  sku           String   @unique
  nameFa        String
  categoryId    String?
  unitId        String
  salePrice     Decimal  @db.Decimal(18, 2)
  purchasePrice Decimal  @db.Decimal(18, 2)
  taxRate       Decimal  @default(0) @db.Decimal(5, 2)
  minStock      Decimal  @default(0) @db.Decimal(18, 3)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category ProductCategory? @relation(fields: [categoryId], references: [id])
  unit     Unit             @relation(fields: [unitId], references: [id])

  stockItems    StockItem[]
  inventoryTxns InventoryTxn[]
  salesItems    SalesItem[]
  purchaseItems PurchaseItem[]
}

model Warehouse {
  id        String   @id @default(uuid())
  nameFa    String
  address   String?
  createdAt DateTime @default(now())

  stockItems StockItem[]
}

model StockItem {
  id          String   @id @default(uuid())
  productId   String
  warehouseId String
  qty         Decimal  @default(0) @db.Decimal(18, 3)
  /// میانگین بهای واحد برای ارزش‌گذاری موجودی (روش AVG)
  avgCost     Decimal? @db.Decimal(18, 2)
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
}

model InventoryTxn {
  id              String           @id @default(uuid())
  type            InventoryTxnType
  productId       String
  fromWarehouseId String?
  toWarehouseId   String?
  qty             Decimal          @db.Decimal(18, 3)
  unitCost        Decimal?         @db.Decimal(18, 2)
  referenceType   String?
  referenceId     String?
  happenedAt      DateTime         @default(now())
  actorUserId     String?

  product Product @relation(fields: [productId], references: [id])
}

model SalesInvoice {
  id            String               @id @default(uuid())
  number        String               @unique
  customerId    String
  status        InvoicePaymentStatus @default(UNPAID)
  currency      Currency             @default(IRR)
  subtotal      Decimal              @db.Decimal(18, 2)
  discountTotal Decimal              @default(0) @db.Decimal(18, 2)
  taxTotal      Decimal              @default(0) @db.Decimal(18, 2)
  total         Decimal              @db.Decimal(18, 2)
  issuedAt      DateTime             @default(now())
  dueDate       DateTime?
  notes         String?
  createdAt     DateTime             @default(now())

  customer Customer    @relation(fields: [customerId], references: [id])
  items    SalesItem[]
}

model SalesItem {
  id        String  @id @default(uuid())
  invoiceId String
  productId String
  qty       Decimal @db.Decimal(18, 3)
  unitPrice Decimal @db.Decimal(18, 2)
  taxRate   Decimal @default(0) @db.Decimal(5, 2)
  discount  Decimal @default(0) @db.Decimal(18, 2)
  total     Decimal @db.Decimal(18, 2)

  invoice SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])
}

model PurchaseInvoice {
  id            String               @id @default(uuid())
  number        String               @unique
  supplierId    String
  status        InvoicePaymentStatus @default(UNPAID)
  currency      Currency             @default(IRR)
  subtotal      Decimal              @db.Decimal(18, 2)
  discountTotal Decimal              @default(0) @db.Decimal(18, 2)
  taxTotal      Decimal              @default(0) @db.Decimal(18, 2)
  total         Decimal              @db.Decimal(18, 2)
  issuedAt      DateTime             @default(now())
  notes         String?
  createdAt     DateTime             @default(now())

  supplier Supplier       @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]
}

model PurchaseItem {
  id        String  @id @default(uuid())
  invoiceId String
  productId String
  qty       Decimal @db.Decimal(18, 3)
  unitCost  Decimal @db.Decimal(18, 2)
  taxRate   Decimal @default(0) @db.Decimal(5, 2)
  discount  Decimal @default(0) @db.Decimal(18, 2)
  total     Decimal @db.Decimal(18, 2)

  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
}

model Account {
  id        String      @id @default(uuid())
  code      String      @unique
  nameFa    String
  type      AccountType
  parentId  String?
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())

  parent   Account?      @relation("AccountParent", fields: [parentId], references: [id])
  children Account[]     @relation("AccountParent")
  lines    JournalLine[]
}

model JournalEntry {
  id          String   @id @default(uuid())
  number      String
  date        DateTime @default(now())
  memo        String?
  sourceType  String?
  sourceId    String?
  actorUserId String?
  createdAt   DateTime @default(now())

  lines JournalLine[]

  @@index([date])
}

model JournalLine {
  id        String  @id @default(uuid())
  entryId   String
  accountId String
  debit     Decimal @default(0) @db.Decimal(18, 2)
  credit    Decimal @default(0) @db.Decimal(18, 2)

  entry   JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])

  @@index([accountId])
}

model Payment {
  id            String           @id @default(uuid())
  direction     PaymentDirection
  amount        Decimal          @db.Decimal(18, 2)
  method        String
  fromAccountId String?
  toAccountId   String?
  referenceType String?
  referenceId   String?
  happenedAt    DateTime         @default(now())
  actorUserId   String?
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  diff        Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
}
